---
import "../styles/globals.css";

import LocaleMenu from "@/components/landing/LocaleMenu.astro";
import { Button } from "@/components/ui/button";
import {
	DEFAULT_LOCALE,
	SUPPORTED_LOCALES,
	detectLocaleFromHeader,
	localeLabels,
	resolveLocale,
	translations,
	type Locale,
} from "@/i18n/translations";

export const prerender = false;

const brandName = "ZShip Code";
const loginUrl = "https://ai.zship.ai/login";
const detailsAnchor = "details";
const currentLocale =
	resolveLocale(Astro.url.searchParams.get("lang")) ??
	detectLocaleFromHeader(Astro.request.headers.get("accept-language")) ??
	DEFAULT_LOCALE;
const copy = translations[currentLocale];

const localeItems = SUPPORTED_LOCALES.map((locale) => ({
	code: locale,
	label: localeLabels[locale],
	href: `/?lang=${locale}`,
	active: locale === currentLocale,
}));

const heroCopy: Record<Locale, { title: string; description: string; note: string }> = {
	"zh-CN": {
		title: "全球领先的 AI API 聚合平台",
		description:
			"一站式接入 Claude、Claude Code、GPT、Codex、Gemini、Azure OpenAI 等主流 AI 服务。",
		note: "为全球开发者提供稳定高效的 API 服务。",
	},
	"zh-TW": {
		title: "全球領先的 AI API 聚合平台",
		description:
			"一站式接入 Claude、Claude Code、GPT、Codex、Gemini、Azure OpenAI 等主流 AI 服務。",
		note: "為全球開發者提供穩定高效的 API 服務。",
	},
	en: {
		title: "Leading global AI API platform",
		description: "One place to access Claude, Claude Code, GPT, Codex, Gemini, and Azure OpenAI.",
		note: "Stable, efficient API delivery for global developers.",
	},
	de: {
		title: "Führende globale AI API Plattform",
		description: "Ein Zugang für Claude, Claude Code, GPT, Codex, Gemini und Azure OpenAI.",
		note: "Stabile und effiziente APIs für Entwickler weltweit.",
	},
	fr: {
		title: "Plateforme API IA leader à l'échelle mondiale",
		description: "Un accès unique à Claude, Claude Code, GPT, Codex, Gemini et Azure OpenAI.",
		note: "Des API stables et efficaces pour les développeurs du monde entier.",
	},
	ja: {
		title: "世界をリードする AI API プラットフォーム",
		description: "Claude、Claude Code、GPT、Codex、Gemini、Azure OpenAI を一つの入口で接続。",
		note: "世界中の開発者に安定した効率的な API を提供します。",
	},
	ko: {
		title: "글로벌 선도 AI API 플랫폼",
		description: "Claude, Claude Code, GPT, Codex, Gemini, Azure OpenAI를 하나의 플랫폼에서 연결합니다.",
		note: "전 세계 개발자를 위한 안정적이고 효율적인 API.",
	},
	pt: {
		title: "Plataforma global líder de API de IA",
		description: "Acesse Claude, Claude Code, GPT, Codex, Gemini e Azure OpenAI em um só lugar.",
		note: "APIs estáveis e eficientes para desenvolvedores globais.",
	},
	tr: {
		title: "Lider global AI API platformu",
		description: "Claude, Claude Code, GPT, Codex, Gemini ve Azure OpenAI'ye tek yerden erişin.",
		note: "Küresel geliştiriciler için istikrarlı ve verimli API hizmeti.",
	},
	es: {
		title: "Plataforma global líder de API de IA",
		description: "Accede a Claude, Claude Code, GPT, Codex, Gemini y Azure OpenAI desde un solo lugar.",
		note: "API estables y eficientes para desarrolladores globales.",
	},
	ru: {
		title: "Ведущая мировая AI API платформа",
		description: "Единый доступ к Claude, Claude Code, GPT, Codex, Gemini и Azure OpenAI.",
		note: "Стабильные и эффективные API для разработчиков по всему миру.",
	},
};

const footerCopy: Record<
	Locale,
	{
		internal: string;
		legal: string;
		home: string;
		features: string;
		login: string;
		privacy: string;
		refund: string;
		terms: string;
	}
> = {
	"zh-CN": {
		internal: "站内链接",
		legal: "法律条款",
		home: "首页",
		features: "功能",
		login: "登录",
		privacy: "隐私政策",
		refund: "退款政策",
		terms: "服务条款",
	},
	"zh-TW": {
		internal: "站內連結",
		legal: "法律條款",
		home: "首頁",
		features: "功能",
		login: "登入",
		privacy: "隱私政策",
		refund: "退款政策",
		terms: "服務條款",
	},
	en: {
		internal: "Internal",
		legal: "Legal",
		home: "Home",
		features: "Features",
		login: "Login",
		privacy: "Privacy",
		refund: "Refund",
		terms: "Terms",
	},
	de: {
		internal: "Intern",
		legal: "Rechtliches",
		home: "Start",
		features: "Funktionen",
		login: "Login",
		privacy: "Datenschutz",
		refund: "Erstattung",
		terms: "AGB",
	},
	fr: {
		internal: "Interne",
		legal: "Légal",
		home: "Accueil",
		features: "Fonctionnalités",
		login: "Connexion",
		privacy: "Confidentialité",
		refund: "Remboursement",
		terms: "Conditions",
	},
	ja: {
		internal: "内部リンク",
		legal: "リーガル",
		home: "ホーム",
		features: "機能",
		login: "ログイン",
		privacy: "プライバシー",
		refund: "返金",
		terms: "利用規約",
	},
	ko: {
		internal: "내부 링크",
		legal: "법률",
		home: "홈",
		features: "기능",
		login: "로그인",
		privacy: "개인정보",
		refund: "환불",
		terms: "이용약관",
	},
	pt: {
		internal: "Interno",
		legal: "Legal",
		home: "Início",
		features: "Recursos",
		login: "Entrar",
		privacy: "Privacidade",
		refund: "Reembolso",
		terms: "Termos",
	},
	tr: {
		internal: "Dahili",
		legal: "Yasal",
		home: "Ana sayfa",
		features: "Ozellikler",
		login: "Giris",
		privacy: "Gizlilik",
		refund: "Iade",
		terms: "Kosullar",
	},
	es: {
		internal: "Interno",
		legal: "Legal",
		home: "Inicio",
		features: "Funciones",
		login: "Acceso",
		privacy: "Privacidad",
		refund: "Reembolso",
		terms: "Términos",
	},
	ru: {
		internal: "Навигация",
		legal: "Правовая информация",
		home: "Главная",
		features: "Возможности",
		login: "Вход",
		privacy: "Конфиденциальность",
		refund: "Возврат",
		terms: "Условия",
	},
};

const replaceBrand = (value: string) => value.replaceAll("ZShipCode", brandName);

const homeUrl = new URL(Astro.url);
homeUrl.pathname = "/";
homeUrl.search = "";
homeUrl.searchParams.set("lang", currentLocale);

const pageTitle = replaceBrand(copy.metaTitle);
const pageDescription = replaceBrand(copy.metaDescription);
---

<!doctype html>
<html lang={currentLocale}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
		<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />
		<link rel="canonical" href={homeUrl.toString()} />
		<title>{pageTitle}</title>
		<meta name="title" content={pageTitle} />
		<meta name="description" content={pageDescription} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={homeUrl.toString()} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:title" content={pageTitle} />
		<meta property="twitter:description" content={pageDescription} />
	</head>
	<body>
		<div class="relative" id="top">
			<div class="pointer-events-none absolute inset-x-0 top-0 h-[30rem] bg-[radial-gradient(circle_at_50%_0%,rgba(201,100,66,0.11),transparent_54%)]" />

			<div class="relative mx-auto w-[min(calc(100%-40px),1180px)] pb-14 pt-5 max-md:w-[min(calc(100%-24px),1180px)]">
				<header class="sticky top-0 z-30 flex items-center justify-between gap-2.5 rounded-full border border-[#ece6d8] bg-[#faf9f5]/88 px-3 py-1 shadow-[0_0_0_1px_rgba(209,207,197,0.22),0_12px_34px_rgba(20,20,19,0.05)] backdrop-blur-xl">
					<a class="inline-flex min-w-0 items-center gap-2.5 rounded-full px-2 py-1" href={`/?lang=${currentLocale}`}>
						<img alt={`${brandName} logo`} class="size-9 object-contain" height="36" src="/logo.png" width="36" />
						<span class="text-[1rem] font-semibold tracking-[-0.02em] text-[#141413] max-[420px]:hidden">{brandName}</span>
					</a>

					<div class="flex items-center gap-2 max-sm:flex-1 max-sm:justify-end">
						<LocaleMenu
							currentLabel={localeLabels[currentLocale]}
							items={localeItems}
							label={copy.nav.languageLabel}
						/>

						<Button
							as="a"
							class="h-9 rounded-full border-[#c96442] bg-[#c96442] px-5 text-sm font-semibold text-[#faf9f5] shadow-[0_0_0_1px_#c96442] hover:bg-[#d97757] max-sm:px-4"
							href={loginUrl}
							size="lg"
						>
							{copy.nav.login}
						</Button>
					</div>
				</header>

				<main class="pt-12 md:pt-16">
					<section class="flex min-h-[calc(100svh-8rem)] items-center justify-center pb-14">
						<div class="mx-auto flex max-w-5xl flex-col items-center pt-6 text-center md:pt-10">
							<h1 class="text-balance text-[clamp(3.5rem,8vw,6.8rem)] leading-[0.9] text-[#141413]">
								{heroCopy[currentLocale].title}
							</h1>
							<p class="mt-6 max-w-[44rem] text-[1.06rem] leading-8 text-[#55534d] md:text-[1.14rem] md:leading-9">
								{heroCopy[currentLocale].description}
							</p>
							<p class="mt-3 max-w-[34rem] text-[0.98rem] leading-7 text-[#7d766b]">{heroCopy[currentLocale].note}</p>

							<div class="mt-9 flex flex-wrap items-center justify-center gap-4">
								<Button
									as="a"
									class="h-12 rounded-full border-[#c96442] bg-[#c96442] px-6 text-sm font-semibold text-[#faf9f5] shadow-[0_0_0_1px_#c96442] hover:bg-[#d97757]"
									href={loginUrl}
									size="lg"
								>
									{copy.hero.primaryAction}
								</Button>

								<a
									class="inline-flex items-center text-sm font-medium text-[#4d4c48] transition-colors hover:text-[#141413]"
									href={`#${detailsAnchor}`}
								>
									{copy.hero.secondaryAction}
								</a>
							</div>

							<div class="mt-14 grid w-full gap-5 border-t border-[#e8e2d6] pt-6 sm:grid-cols-3">
								{
									copy.stats.map((item) => (
										<div class="space-y-1">
											<p class="text-[2rem] leading-none text-[#141413]">{item.value}</p>
											<p class="text-sm leading-6 text-[#6d665b]">{item.label}</p>
										</div>
									))
								}
							</div>
						</div>
					</section>

					<section class="grid gap-10 border-t border-[#e8e2d6] py-12 lg:grid-cols-[0.72fr_1.28fr] lg:gap-14" id={detailsAnchor}>
						<div class="max-w-[24rem]">
							<p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[#857d71]">{copy.features.label}</p>
							<h2 class="mt-4 max-w-[11ch] text-[clamp(2rem,4vw,3.35rem)] leading-[1.03] text-[#141413]">
								{copy.panel.title}
							</h2>
							<p class="mt-5 text-[1rem] leading-8 text-[#5e5d59]">{copy.panel.description}</p>
						</div>

						<div class="divide-y divide-[#e8e2d6]">
							{
								copy.features.items.map((feature, index) => (
									<div class="grid gap-4 py-6 md:grid-cols-[72px_minmax(0,1fr)] md:gap-6">
										<p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[#8c8579]">
											{String(index + 1).padStart(2, "0")}
										</p>
										<div>
											<h3 class="text-[1.7rem] leading-[1.08] text-[#141413]">
												{replaceBrand(feature.title)}
											</h3>
											<p class="mt-3 max-w-[44rem] text-[0.98rem] leading-8 text-[#5e5d59]">
												{replaceBrand(feature.description)}
											</p>
										</div>
									</div>
								))
							}
						</div>
					</section>
				</main>

				<footer class="border-t border-[#e8e2d6] py-8 md:py-10">
					<div class="grid gap-10 md:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)] md:gap-12">
						<div class="max-w-md">
							<a class="inline-flex items-center gap-3" href={`/?lang=${currentLocale}`}>
								<img alt={`${brandName} logo`} class="size-9 object-contain" height="36" src="/logo.png" width="36" />
								<span class="text-[1rem] font-semibold tracking-[-0.02em] text-[#141413]">{brandName}</span>
							</a>
							<p class="mt-4 text-[0.95rem] leading-7 text-[#7a7469]">{replaceBrand(copy.footer)}</p>
						</div>

						<div class="grid gap-8 sm:grid-cols-2">
							<div>
								<p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[#8b8479]">
									{footerCopy[currentLocale].internal}
								</p>
								<div class="mt-4 flex flex-col gap-3">
									<a class="text-[0.95rem] text-[#4d4c48] transition-colors hover:text-[#141413]" href="#top">
										{footerCopy[currentLocale].home}
									</a>
									<a class="text-[0.95rem] text-[#4d4c48] transition-colors hover:text-[#141413]" href={`#${detailsAnchor}`}>
										{footerCopy[currentLocale].features}
									</a>
									<a class="text-[0.95rem] text-[#4d4c48] transition-colors hover:text-[#141413]" href={loginUrl}>
										{footerCopy[currentLocale].login}
									</a>
								</div>
							</div>

							<div>
								<p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[#8b8479]">
									{footerCopy[currentLocale].legal}
								</p>
								<div class="mt-4 flex flex-col gap-3">
									<a class="text-[0.95rem] text-[#4d4c48] transition-colors hover:text-[#141413]" href="#privacy-policy">
										{footerCopy[currentLocale].privacy}
									</a>
									<a class="text-[0.95rem] text-[#4d4c48] transition-colors hover:text-[#141413]" href="#refund-policy">
										{footerCopy[currentLocale].refund}
									</a>
									<a class="text-[0.95rem] text-[#4d4c48] transition-colors hover:text-[#141413]" href="#terms-of-service">
										{footerCopy[currentLocale].terms}
									</a>
								</div>
							</div>
						</div>
					</div>
				</footer>

				<div aria-hidden="true" class="sr-only">
					<div id="privacy-policy"></div>
					<div id="refund-policy"></div>
					<div id="terms-of-service"></div>
				</div>
			</div>
		</div>
	</body>
</html>
