---
import "../styles/globals.css";

import LocaleMenu from "@/components/landing/LocaleMenu.astro";
import { Button } from "@/components/ui/button";
import {
	DEFAULT_LOCALE,
	SUPPORTED_LOCALES,
	detectLocaleFromHeader,
	localeLabels,
	resolveLocale,
	translations,
	type Locale,
} from "@/i18n/translations";

export const prerender = false;

const brandName = "ZShip Code";
const loginUrl = "https://ai.zship.ai/login";
const detailsAnchor = "details";
const currentLocale =
	resolveLocale(Astro.url.searchParams.get("lang")) ??
	detectLocaleFromHeader(Astro.request.headers.get("accept-language")) ??
	DEFAULT_LOCALE;
const copy = translations[currentLocale];

const localeItems = SUPPORTED_LOCALES.map((locale) => ({
	code: locale,
	label: localeLabels[locale],
	href: `/?lang=${locale}`,
	active: locale === currentLocale,
}));

const modelIcons = [
	{ src: "/ref/claude.svg", label: "Claude Code" },
	{ src: "/ref/openai.svg", label: "Codex" },
	{ src: "/ref/gemini.svg", label: "Gemini CLI" },
	{ src: "/ref/openclaw-logo.svg", label: "OpenClaw" },
];

const toolIcons = [
	{ src: "/ref/vscode.svg", label: "VS Code" },
	{ src: "/ref/jetbrains.svg", label: "JetBrains" },
];

const platformIcons = [
	{ src: "/ref/macos.svg", label: "macOS" },
	{ src: "/ref/windows.svg", label: "Windows" },
	{ src: "/ref/linux.svg", label: "Linux" },
];

const landingCopy =
	currentLocale === "zh-CN"
		? {
				metaTitle: `${brandName} | 专为日常编码而设计的一站式 AI 体验`,
				metaDescription:
					"ZShip Code 专为日常编码而设计的一站式体验。更低的价格，更简单的配置，让每位开发者都能用上 Claude Code、Codex、Gemini CLI、OpenClaw 等顶级 AI 编码模型。",
				hero: {
					title: "一个账号，接入顶级 AI 编码模型",
					description:
						"更低的价格，更简单的配置，让每位开发者都能用上顶级 AI 编码模型。",
					note: "一个 ZShip Code 账号，同时使用 Claude Code 和 Codex。统一的 API 接入与网络环境，把时间还给你的代码，而不是配置面板。",
				},
				stats: [
					{ value: "1 个账号", label: "同时使用 Claude Code 与 Codex" },
					{ value: "1 套配置", label: "统一域名与密钥格式" },
					{ value: "macOS / Windows / Linux", label: "跨平台保持一致体验" },
				],
				section: {
					eyebrow: "为编码工作流而生",
					title: "少一点配置，多一点写代码。",
					description:
						"统一的网络环境、密钥格式和接入方式，覆盖常见 IDE 插件与 CLI 工具，把环境准备成本压到最低。",
					rows: [
						{
							title: "支持主流 AI 编码模型",
							description:
								"一个账号即可接入 Claude Code、OpenAI Codex、Gemini CLI、OpenClaw 等常见编码模型与工具。",
							icons: modelIcons,
						},
						{
							title: "覆盖常见 IDE 与 CLI 工具",
							description:
								"兼容 VS Code、JetBrains 等开发环境，统一域名与密钥格式，一键配置环境。",
							icons: toolIcons,
						},
						{
							title: "跨平台一致可用",
							description:
								"支持 macOS、Windows、Linux，不必为不同设备反复重配网络、密钥和调用方式。",
							icons: platformIcons,
						},
					],
				},
				footer:
					"ZShip Code 让开发者用一个账号和一套配置，更轻松地使用顶级 AI 编码模型。",
		  }
		: currentLocale === "zh-TW"
			? {
					metaTitle: `${brandName} | 專為日常編碼而設計的一站式 AI 體驗`,
					metaDescription:
						"ZShip Code 專為日常編碼而設計的一站式體驗。更低的價格，更簡單的設定，讓每位開發者都能用上 Claude Code、Codex、Gemini CLI、OpenClaw 等頂級 AI 編碼模型。",
					hero: {
						title: "一個帳號，接入頂級 AI 編碼模型",
						description: "更低的價格，更簡單的設定，讓每位開發者都能用上頂級 AI 編碼模型。",
						note: "一個 ZShip Code 帳號，同時使用 Claude Code 和 Codex。統一的 API 接入與網路環境，把時間還給你的程式碼，而不是設定面板。",
					},
					stats: [
						{ value: "1 個帳號", label: "同時使用 Claude Code 與 Codex" },
						{ value: "1 套設定", label: "統一網域與金鑰格式" },
						{ value: "macOS / Windows / Linux", label: "跨平台維持一致體驗" },
					],
					section: {
						eyebrow: "為編碼工作流而生",
						title: "少一點設定，多一點寫程式。",
						description:
							"統一的網路環境、金鑰格式與接入方式，覆蓋常見 IDE 外掛與 CLI 工具，把環境準備成本壓到最低。",
						rows: [
							{
								title: "支援主流 AI 編碼模型",
								description:
									"一個帳號即可接入 Claude Code、OpenAI Codex、Gemini CLI、OpenClaw 等常見編碼模型與工具。",
								icons: modelIcons,
							},
							{
								title: "覆蓋常見 IDE 與 CLI 工具",
								description:
									"相容 VS Code、JetBrains 等開發環境，統一網域與金鑰格式，一鍵配置環境。",
								icons: toolIcons,
							},
							{
								title: "跨平台一致可用",
								description:
									"支援 macOS、Windows、Linux，不必為不同裝置反覆重配網路、金鑰與呼叫方式。",
								icons: platformIcons,
							},
						],
					},
					footer: "ZShip Code 讓開發者用一個帳號和一套設定，更輕鬆地使用頂級 AI 編碼模型。",
			  }
			: {
					metaTitle: `${brandName} | One account for top AI coding models`,
					metaDescription:
						"ZShip Code is built for daily coding. Lower cost and simpler setup let developers use Claude Code, Codex, Gemini CLI, and OpenClaw through one cleaner workflow.",
					hero: {
						title: "One account for AI coding models",
						description:
							"Built for daily coding with lower cost, simpler setup, and a cleaner path to top AI coding tools.",
						note: "Use Claude Code and Codex from one ZShip Code account. Unified API access and network setup keep your time on code instead of config panels.",
					},
					stats: [
						{ value: "1 account", label: "Use Claude Code and Codex together" },
						{ value: "1 format", label: "Unified domain and key format" },
						{ value: "macOS / Windows / Linux", label: "Consistent setup across platforms" },
					],
					section: {
						eyebrow: "Built for coding workflows",
						title: "Less configuration, more code.",
						description:
							"One access layer for domains, keys, and network setup across common IDE plugins and CLI tools, so environment work stops eating engineering time.",
						rows: [
							{
								title: "Support for mainstream AI coding tools",
								description:
									"Use Claude Code, OpenAI Codex, Gemini CLI, and OpenClaw through one account and one consistent access path.",
								icons: modelIcons,
							},
							{
								title: "Works across IDE and CLI workflows",
								description:
									"Cover common environments like VS Code and JetBrains with one domain and key format for faster setup.",
								icons: toolIcons,
							},
							{
								title: "Same setup on every major OS",
								description:
									"Run the same workflow on macOS, Windows, and Linux without repeating network and credential configuration.",
								icons: platformIcons,
							},
						],
					},
					footer:
						"ZShip Code gives developers one account and one cleaner setup for top AI coding models across IDEs, CLIs, and operating systems.",
			  };

const footerCopy: Record<
	Locale,
	{
		internal: string;
		legal: string;
		home: string;
		features: string;
		login: string;
		privacy: string;
		refund: string;
		terms: string;
	}
> = {
	"zh-CN": {
		internal: "站内链接",
		legal: "法律条款",
		home: "首页",
		features: "功能",
		login: "登录",
		privacy: "隐私政策",
		refund: "退款政策",
		terms: "服务条款",
	},
	"zh-TW": {
		internal: "站內連結",
		legal: "法律條款",
		home: "首頁",
		features: "功能",
		login: "登入",
		privacy: "隱私政策",
		refund: "退款政策",
		terms: "服務條款",
	},
	en: {
		internal: "Internal",
		legal: "Legal",
		home: "Home",
		features: "Features",
		login: "Login",
		privacy: "Privacy",
		refund: "Refund",
		terms: "Terms",
	},
	de: {
		internal: "Intern",
		legal: "Rechtliches",
		home: "Start",
		features: "Funktionen",
		login: "Login",
		privacy: "Datenschutz",
		refund: "Erstattung",
		terms: "AGB",
	},
	fr: {
		internal: "Interne",
		legal: "Légal",
		home: "Accueil",
		features: "Fonctionnalités",
		login: "Connexion",
		privacy: "Confidentialité",
		refund: "Remboursement",
		terms: "Conditions",
	},
	ja: {
		internal: "内部リンク",
		legal: "リーガル",
		home: "ホーム",
		features: "機能",
		login: "ログイン",
		privacy: "プライバシー",
		refund: "返金",
		terms: "利用規約",
	},
	ko: {
		internal: "내부 링크",
		legal: "법률",
		home: "홈",
		features: "기능",
		login: "로그인",
		privacy: "개인정보",
		refund: "환불",
		terms: "이용약관",
	},
	pt: {
		internal: "Interno",
		legal: "Legal",
		home: "Início",
		features: "Recursos",
		login: "Entrar",
		privacy: "Privacidade",
		refund: "Reembolso",
		terms: "Termos",
	},
	tr: {
		internal: "Dahili",
		legal: "Yasal",
		home: "Ana sayfa",
		features: "Ozellikler",
		login: "Giris",
		privacy: "Gizlilik",
		refund: "Iade",
		terms: "Kosullar",
	},
	es: {
		internal: "Interno",
		legal: "Legal",
		home: "Inicio",
		features: "Funciones",
		login: "Acceso",
		privacy: "Privacidad",
		refund: "Reembolso",
		terms: "Términos",
	},
	ru: {
		internal: "Навигация",
		legal: "Правовая информация",
		home: "Главная",
		features: "Возможности",
		login: "Вход",
		privacy: "Конфиденциальность",
		refund: "Возврат",
		terms: "Условия",
	},
};

const homeUrl = new URL(Astro.url);
homeUrl.pathname = "/";
homeUrl.search = "";
homeUrl.searchParams.set("lang", currentLocale);

const pageTitle = landingCopy.metaTitle;
const pageDescription = landingCopy.metaDescription;
---

<!doctype html>
<html lang={currentLocale}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/favicon.ico" />
		<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
		<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />
		<link rel="canonical" href={homeUrl.toString()} />
		<title>{pageTitle}</title>
		<meta name="title" content={pageTitle} />
		<meta name="description" content={pageDescription} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={homeUrl.toString()} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:title" content={pageTitle} />
		<meta property="twitter:description" content={pageDescription} />
	</head>
	<body>
		<div class="relative" id="top">
			<div class="pointer-events-none absolute inset-x-0 top-0 h-[30rem] bg-[radial-gradient(circle_at_50%_0%,rgba(201,100,66,0.11),transparent_54%)]" />

			<div class="relative mx-auto w-[min(calc(100%-40px),1180px)] pb-14 pt-5 max-md:w-[min(calc(100%-24px),1180px)]">
				<header class="sticky top-0 z-30 flex items-center justify-between gap-2.5 rounded-full border border-[#ece6d8] bg-[#faf9f5]/88 px-3 py-1 shadow-[0_0_0_1px_rgba(209,207,197,0.22),0_12px_34px_rgba(20,20,19,0.05)] backdrop-blur-xl">
					<a
						class="inline-flex min-w-0 items-center gap-2.5 rounded-full px-2 py-1"
						href={`/?lang=${currentLocale}`}
						rel="noopener noreferrer"
						target="_blank"
					>
						<img alt={`${brandName} logo`} class="size-9 object-contain" height="36" src="/logo.png" width="36" />
						<span class="text-[1rem] font-semibold tracking-[-0.02em] text-[#141413] max-[420px]:hidden">{brandName}</span>
					</a>

					<div class="flex items-center gap-2 max-sm:flex-1 max-sm:justify-end">
						<LocaleMenu
							currentLabel={localeLabels[currentLocale]}
							items={localeItems}
							label={copy.nav.languageLabel}
						/>

						<Button
							as="a"
							class="h-9 rounded-full border-[#c96442] bg-[#c96442] px-5 text-sm font-semibold text-[#faf9f5] shadow-[0_0_0_1px_#c96442] hover:bg-[#d97757] max-sm:px-4"
							href={loginUrl}
							size="lg"
						>
							{copy.nav.login}
						</Button>
					</div>
				</header>

				<main class="pt-12 md:pt-16">
					<section class="flex min-h-[calc(100svh-8rem)] items-center justify-center pb-14">
						<div class="mx-auto flex max-w-5xl flex-col items-center pt-6 text-center md:pt-10">
							<h1 class="text-balance text-[clamp(3.5rem,8vw,6.8rem)] leading-[0.9] text-[#141413]">
								{landingCopy.hero.title}
							</h1>
							<p class="mt-6 max-w-[44rem] text-[1.06rem] leading-8 text-[#55534d] md:text-[1.14rem] md:leading-9">
								{landingCopy.hero.description}
							</p>
							<p class="mt-3 max-w-[42rem] text-[0.98rem] leading-7 text-[#7d766b]">{landingCopy.hero.note}</p>

							<div class="mt-9 flex flex-wrap items-center justify-center gap-4">
								<Button
									as="a"
									class="h-12 rounded-full border-[#c96442] bg-[#c96442] px-6 text-sm font-semibold text-[#faf9f5] shadow-[0_0_0_1px_#c96442] hover:bg-[#d97757]"
									href={loginUrl}
									size="lg"
								>
									{copy.hero.primaryAction}
								</Button>

								<a
									class="inline-flex items-center text-sm font-medium text-[#4d4c48] transition-colors hover:text-[#141413]"
									href={`#${detailsAnchor}`}
								>
									{copy.hero.secondaryAction}
								</a>
							</div>

							<div class="mt-14 grid w-full gap-5 border-t border-[#e8e2d6] pt-6 sm:grid-cols-3">
								{
									landingCopy.stats.map((item) => (
										<div class="space-y-1">
											<p class="text-[2rem] leading-none text-[#141413]">{item.value}</p>
											<p class="text-sm leading-6 text-[#6d665b]">{item.label}</p>
										</div>
									))
								}
							</div>
						</div>
					</section>

					<section class="grid gap-10 border-t border-[#e8e2d6] py-12 lg:grid-cols-[0.72fr_1.28fr] lg:gap-14" id={detailsAnchor}>
						<div class="max-w-[24rem]">
							<p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[#857d71]">{landingCopy.section.eyebrow}</p>
							<h2 class="mt-4 max-w-[11ch] text-[clamp(2rem,4vw,3.35rem)] leading-[1.03] text-[#141413]">
								{landingCopy.section.title}
							</h2>
							<p class="mt-5 text-[1rem] leading-8 text-[#5e5d59]">{landingCopy.section.description}</p>
						</div>

						<div class="divide-y divide-[#e8e2d6]">
							{
								landingCopy.section.rows.map((feature, index) => (
									<div class="grid gap-4 py-6 md:grid-cols-[72px_minmax(0,1fr)] md:gap-6">
										<p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[#8c8579]">
											{String(index + 1).padStart(2, "0")}
										</p>
										<div>
											<h3 class="text-[1.7rem] leading-[1.08] text-[#141413]">
												{feature.title}
											</h3>
											<p class="mt-3 max-w-[44rem] text-[0.98rem] leading-8 text-[#5e5d59]">
												{feature.description}
											</p>
											<div class="mt-5 flex flex-wrap gap-2.5">
												{
													feature.icons.map((icon) => (
														<div class="inline-flex items-center gap-2 rounded-full border border-[#e8e2d6] bg-[#faf8f2] px-3 py-1.5 text-[#4d4c48] shadow-[0_0_0_1px_rgba(209,207,197,0.18)]">
															<img
																alt={`${icon.label} logo`}
																class="size-4 object-contain"
																height="16"
																src={icon.src}
																width="16"
															/>
															<span class="text-[0.88rem] font-medium leading-none">{icon.label}</span>
														</div>
													))
												}
											</div>
										</div>
									</div>
								))
							}
						</div>
					</section>
				</main>

				<footer class="border-t border-[#e8e2d6] py-8 md:py-10">
					<div class="grid gap-10 md:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)] md:gap-12">
						<div class="max-w-md">
							<a
								class="inline-flex items-center gap-3"
								href={`/?lang=${currentLocale}`}
								rel="noopener noreferrer"
								target="_blank"
							>
								<img alt={`${brandName} logo`} class="size-9 object-contain" height="36" src="/logo.png" width="36" />
								<span class="text-[1rem] font-semibold tracking-[-0.02em] text-[#141413]">{brandName}</span>
							</a>
							<p class="mt-4 text-[0.95rem] leading-7 text-[#7a7469]">{landingCopy.footer}</p>
						</div>

						<div class="grid gap-8 sm:grid-cols-2">
							<div>
								<p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[#8b8479]">
									{footerCopy[currentLocale].internal}
								</p>
								<div class="mt-4 flex flex-col gap-3">
									<a class="text-[0.95rem] text-[#4d4c48] transition-colors hover:text-[#141413]" href="#top">
										{footerCopy[currentLocale].home}
									</a>
									<a class="text-[0.95rem] text-[#4d4c48] transition-colors hover:text-[#141413]" href={`#${detailsAnchor}`}>
										{footerCopy[currentLocale].features}
									</a>
									<a class="text-[0.95rem] text-[#4d4c48] transition-colors hover:text-[#141413]" href={loginUrl}>
										{footerCopy[currentLocale].login}
									</a>
								</div>
							</div>

							<div>
								<p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[#8b8479]">
									{footerCopy[currentLocale].legal}
								</p>
								<div class="mt-4 flex flex-col gap-3">
									<a class="text-[0.95rem] text-[#4d4c48] transition-colors hover:text-[#141413]" href="#privacy-policy">
										{footerCopy[currentLocale].privacy}
									</a>
									<a class="text-[0.95rem] text-[#4d4c48] transition-colors hover:text-[#141413]" href="#refund-policy">
										{footerCopy[currentLocale].refund}
									</a>
									<a class="text-[0.95rem] text-[#4d4c48] transition-colors hover:text-[#141413]" href="#terms-of-service">
										{footerCopy[currentLocale].terms}
									</a>
								</div>
							</div>
						</div>
					</div>
				</footer>

				<div aria-hidden="true" class="sr-only">
					<div id="privacy-policy"></div>
					<div id="refund-policy"></div>
					<div id="terms-of-service"></div>
				</div>
			</div>
		</div>
	</body>
</html>
